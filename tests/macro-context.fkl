(defmacro ~(test-m1)
  (begin
    (import (macro-context-lib))
    (printf "[%s:\t%4d] test-macro-var: %S\n"
            *file*
            *line*
            (get-test-macro-var))
    (inc-test-macro-var)))

(defmacro ~(test-m2)
  (begin
    (import (macro-context-lib))
    (printf "[%s:\t%4d] test-macro-var: %S\n"
            *file*
            *line*
            (get-test-macro-var))
    (inc-test-macro-var)))

(test-m1)
(test-m2)
(test-m2)

(defmacro #&internal
  #[inc-test-macro-var #["#INC#"] custom
                       (begin
                         (import (macro-context-lib))
                         (printf "[%s:\t%4d] test-macro-var: %S\n"
                                 *file*
                                 *line*
                                 (get-test-macro-var))
                         (inc-test-macro-var))])

(printf "[%s:\t%4d] #INC#: %S\n"
            *file*
            *line*
            #INC#)

(printf "[%s:\t%4d] #INC#: %S\n"
            *file*
            *line*
            #INC#)
