(import (only (.. lib utils m) assert macroexpand macroexpand-1))

(defmacro ~(alpha ~a) `(quote ~a))
(defmacro ~(beta ~a) `(alpha ~a))
(defmacro ~(gamma ~a) `(beta ~a))
(defmacro ~(delta ~a) `(gamma ~a))

(defmacro ~(dbg! ~a) `(printf "%-80s: %-40s\n" (quote ~a) ~a))
(defmacro ~(dbg! ~a ~b)
  `(begin
     (assert (equal ~a ~b))
     (printf "%-80s: %-40s\n" (quote ~a) ~a)))

(dbg! (macroexpand-1 (gamma foo)) '(beta foo))
(dbg! (macroexpand-1 (gamma foo) 0) '(beta foo))
(dbg! (macroexpand-1 (macroexpand-1 (gamma foo))) '(alpha foo))
(dbg! (macroexpand-1 (macroexpand-1 (gamma foo)) 0) '(alpha foo))
(dbg! (macroexpand-1 (macroexpand-1 (macroexpand-1 (gamma foo) 0))) '(quote foo))
(dbg! (macroexpand-1 (macroexpand-1 (macroexpand-1 (delta foo) 0))) '(alpha foo))
(dbg! (macroexpand-1 (macroexpand-1 (gamma foo)) 1) '(quote foo))
(dbg! (macroexpand-1 (macroexpand-1 (macroexpand-1 (delta foo)) 0)) '(alpha foo))
(dbg! (macroexpand-1 (macroexpand-1 (macroexpand-1 (delta foo)) 0) 0) '(alpha foo))
(dbg! (macroexpand-1 (macroexpand-1 (macroexpand-1 (delta foo) 0)) 0) '(alpha foo))
(dbg! (macroexpand-1 (macroexpand-1 (macroexpand-1 (delta foo) 0) 0) 0) '(alpha foo))
(dbg! (macroexpand-1 (macroexpand-1 (macroexpand-1 (macroexpand-1 (delta foo)) 0))) '(quote foo))
(dbg! (macroexpand (delta foo)) '(quote foo))
